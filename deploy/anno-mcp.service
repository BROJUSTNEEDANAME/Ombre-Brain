[Unit]
Description=Anno MCP private reading store
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=anno
Group=anno
WorkingDirectory=/opt/marginalia
EnvironmentFile=-/etc/ombre/anno.env
ExecStart=/usr/bin/node /opt/marginalia/server.mjs
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/anno
MemoryMax=550M
TasksMax=128

[Install]
WantedBy=multi-user.target
