# ============================================================
# Claude Code ↔ Telegram 桥 的镜像
# 同时装 Python（跑桥）和 Node + Claude Code CLI（真脑子）。
# 在 Render 上新建一个 Docker 服务，Dockerfile 选这个。
#
# 需要的环境变量见 cc_bridge.py 顶部：
#   TELEGRAM_BOT_TOKEN / ALLOWED_CHAT_IDS / CLAUDE_CODE_OAUTH_TOKEN
# ============================================================

FROM python:3.12-slim

WORKDIR /app

# 装 Node 20 + Claude Code CLI
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates git \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @anthropic-ai/claude-code \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Python 依赖（桥只需要 python-telegram-bot）
COPY requirements-telegram.txt .
RUN pip install --no-cache-dir -r requirements-telegram.txt

# 整个仓库（含 CLAUDE.md + .mcp.json，让 cc 自动加载人设和 ombre-brain 记忆）
COPY . .

CMD ["python", "cc_bridge.py"]
